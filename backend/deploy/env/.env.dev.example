# Spring / Database
DB_USERNAME=passtival
DB_PASSWORD=passtival123
DB_ROOT_PASSWORD=root1234
DB_URL=jdbc:mysql://mysql:3306/passtival-db?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Seoul

# App (dev)
JWT_SECRET_KEY=replace-with-dev-secret-key-min-32-bytes-123456
JWT_ACCESS_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=1209600000
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin1234
ADMIN_SEED_KEY=dev-seed-key
DISCORD_WEBHOOK_URL=localhost:9999/webhook

# OAuth / External
KAKAO_CLIENT_NAME=kakao
KAKAO_CLIENT_ID=replace-with-dev-kakao-client-id
KAKAO_CLIENT_SECRET=replace-with-dev-kakao-client-secret
KAKAO_REDIRECT_URI=http://localhost:8080/login/oauth2/code/kakao
KAKAO_AUTHORIZATION_GRANT_TYPE=authorization_code
KAKAO_SCOPE=profile_nickname,profile_image
KAKAO_AUTHORIZATION_URI=https://kauth.kakao.com/oauth/authorize
KAKAO_TOKEN_URI=https://kauth.kakao.com/oauth/token
KAKAO_USER_INFO_URI=https://kapi.kakao.com/v2/user/me
KAKAO_USER_NAME_ATTRIBUTE=id

# AWS (required placeholders)
AWS_ACCESS_KEY=dummy-access-key
AWS_SECRET_KEY=dummy-secret-key
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=dummy-bucket

# Frontend redirect
FRONTEND_LOGIN_URL=http://localhost:3000/login/success
FRONTEND_LOGIN_FAIL_URL=http://localhost:3000/login/fail

# Optional scheduling
MATCHING_CRON=0 */5 * * * *
MATCHING_CLEANUP_CRON=0 0 * * * *
MATCHING_BLOCK=false
