# Spring / Database
DB_USERNAME=passtival
DB_PASSWORD=replace-with-strong-password
DB_ROOT_PASSWORD=replace-with-strong-root-password

# If using RDS, point DB_URL to external endpoint
DB_URL=jdbc:mysql://your-rds-endpoint:3306/passtival-db?useSSL=true&serverTimezone=Asia/Seoul

# App (prod)
JWT_SECRET_KEY=replace-with-prod-secret-key-min-32-bytes-123456
JWT_ACCESS_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=1209600000
ADMIN_USERNAME=replace-with-admin-username
ADMIN_PASSWORD=replace-with-admin-password
ADMIN_SEED_KEY=replace-with-admin-seed-key
DISCORD_WEBHOOK_URL=replace-with-discord-webhook-host-path

# OAuth / External
KAKAO_CLIENT_NAME=kakao
KAKAO_CLIENT_ID=replace-with-prod-kakao-client-id
KAKAO_CLIENT_SECRET=replace-with-prod-kakao-client-secret
KAKAO_REDIRECT_URI=https://your-domain/login/oauth2/code/kakao
KAKAO_AUTHORIZATION_GRANT_TYPE=authorization_code
KAKAO_SCOPE=profile_nickname,profile_image
KAKAO_AUTHORIZATION_URI=https://kauth.kakao.com/oauth/authorize
KAKAO_TOKEN_URI=https://kauth.kakao.com/oauth/token
KAKAO_USER_INFO_URI=https://kapi.kakao.com/v2/user/me
KAKAO_USER_NAME_ATTRIBUTE=id

# AWS
AWS_ACCESS_KEY=replace-with-aws-access-key
AWS_SECRET_KEY=replace-with-aws-secret-key
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=replace-with-aws-s3-bucket

# Swagger / Frontend
SWAGGER_SERVER_URL=https://api.your-domain
FRONTEND_LOGIN_URL=https://your-frontend/login/success
FRONTEND_LOGIN_FAIL_URL=https://your-frontend/login/fail

# Optional scheduling
MATCHING_CRON=0 */5 * * * *
MATCHING_CLEANUP_CRON=0 0 * * * *
MATCHING_BLOCK=false
